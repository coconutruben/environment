#!/bin/bash
set -euo pipefail

COCOCLAUDE="$HOME/cococlaude"

usage() {
    echo "Usage: claude-setup-dotfiles [--init] <project-path>"
    echo ""
    echo "Symlink CLAUDE.local.md and .claude/ from ~/cococlaude/ into a project."
    echo ""
    echo "  --init   First-time setup: create cococlaude mirror dir and move"
    echo "           existing files into it before symlinking."
    echo ""
    echo "Without --init, silently exits if the project is not in cococlaude."
    exit 1
}

INIT=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --init) INIT=true; shift ;;
        -h|--help) usage ;;
        -*) echo "Unknown flag: $1" >&2; usage ;;
        *) break ;;
    esac
done

[[ $# -lt 1 ]] && usage

TARGET="$(cd "$1" && pwd)"

# Resolve project name from git common dir (works for both main checkouts and worktrees)
GIT_COMMON="$(cd "$TARGET" && git rev-parse --git-common-dir 2>/dev/null)" || {
    echo "ERROR: $TARGET is not inside a git repository" >&2
    exit 1
}
# git returns relative path from worktree; resolve to absolute
GIT_COMMON="$(cd "$TARGET" && cd "$GIT_COMMON" && pwd)"
MAIN_CHECKOUT="$(dirname "$GIT_COMMON")"
PROJECT_NAME="$(basename "$MAIN_CHECKOUT")"

COCO_PROJECT="$COCOCLAUDE/work/$PROJECT_NAME"

if $INIT; then
    # --init: create mirror dir and move existing files
    mkdir -p "$COCO_PROJECT/.claude"

    # Move CLAUDE.local.md if it exists as a real file
    if [ -f "$TARGET/CLAUDE.local.md" ] && [ ! -L "$TARGET/CLAUDE.local.md" ]; then
        mv "$TARGET/CLAUDE.local.md" "$COCO_PROJECT/CLAUDE.local.md"
        echo "cococlaude: moved CLAUDE.local.md -> $COCO_PROJECT/"
    elif [ ! -f "$COCO_PROJECT/CLAUDE.local.md" ]; then
        # Create empty CLAUDE.local.md
        touch "$COCO_PROJECT/CLAUDE.local.md"
        echo "cococlaude: created empty $COCO_PROJECT/CLAUDE.local.md"
    fi

    # Move .claude/ contents if it exists as a real directory
    if [ -d "$TARGET/.claude" ] && [ ! -L "$TARGET/.claude" ]; then
        # Copy contents preserving structure, then remove original
        cp -a "$TARGET/.claude/." "$COCO_PROJECT/.claude/"
        rm -rf "$TARGET/.claude"
        echo "cococlaude: moved .claude/ -> $COCO_PROJECT/.claude/"
    fi
else
    # Without --init: silently exit if project not in cococlaude
    if [ ! -d "$COCO_PROJECT" ]; then
        exit 0
    fi
fi

# Create symlinks

# CLAUDE.local.md
if [ -e "$COCO_PROJECT/CLAUDE.local.md" ]; then
    DEST="$TARGET/CLAUDE.local.md"
    if [ -L "$DEST" ]; then
        : # already a symlink, idempotent
    elif [ -e "$DEST" ]; then
        echo "ERROR: $DEST exists and is a real file. Run with --init to migrate, or move it manually." >&2
        exit 1
    else
        ln -s "$COCO_PROJECT/CLAUDE.local.md" "$DEST"
        echo "cococlaude: linked $DEST"
    fi
fi

# .claude/
if [ -d "$COCO_PROJECT/.claude" ]; then
    DEST="$TARGET/.claude"
    if [ -L "$DEST" ]; then
        : # already a symlink, idempotent
    elif [ -d "$DEST" ]; then
        echo "ERROR: $DEST exists and is a real directory. Run with --init to migrate, or move it manually." >&2
        exit 1
    else
        ln -s "$COCO_PROJECT/.claude" "$DEST"
        echo "cococlaude: linked $DEST"
    fi
fi

# Install post-checkout hook in the main repo (idempotent)
# Only needed for repos that existed before init.templateDir was set
HOOKS_DIR="$GIT_COMMON/hooks"
HOOK="$HOOKS_DIR/post-checkout"
MARKER="# cococlaude"

if [ -f "$HOOK" ] && grep -qF "$MARKER" "$HOOK"; then
    : # already installed
else
    HOOK_SRC="$HOME/environment/git-template/hooks/post-checkout"
    if [ -f "$HOOK_SRC" ]; then
        if [ ! -f "$HOOK" ]; then
            cp "$HOOK_SRC" "$HOOK"
            chmod +x "$HOOK"
        else
            # Append to existing hook
            printf '\n' >> "$HOOK"
            cat "$HOOK_SRC" >> "$HOOK"
        fi
        echo "cococlaude: installed post-checkout hook at $HOOK"
    fi
fi
