#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Build (or rebuild) the image
echo "Building claude-code-env image..."
docker build -q -t claude-code-env "$SCRIPT_DIR/docker"

# Run interactively with selective mounts
# All paths mirror host ~/ so CLAUDE.md instructions work unchanged
# rw: ~/work, ~/claudeandme, ~/.claude, ~/.claude.json, ~/environment_bfl
# ro: ~/environment, ~/oss, ~/.ssh, ~/.gitconfig
# Pass gh token from host keyring so gh CLI works inside container
export GH_TOKEN=$(gh auth token 2>/dev/null || true)

exec docker run -it --rm \
    ${GH_TOKEN:+-e GH_TOKEN} \
    -v ~/work:/home/copus/work \
    -v ~/environment:/home/copus/environment:ro \
    -v ~/environment_bfl:/home/copus/environment_bfl \
    -v ~/oss:/home/copus/oss:ro \
    -v ~/claudeandme:/home/copus/claudeandme \
    -v ~/.claude:/home/copus/.claude \
    -v ~/.claude.json:/home/copus/.claude.json \
    -v ~/.ssh:/home/copus/.ssh:ro \
    -v ~/.gitconfig:/home/copus/.gitconfig:ro \
    -v claude-code-history:/commandhistory \
    claude-code-env \
    claude --dangerously-skip-permissions "$@"
